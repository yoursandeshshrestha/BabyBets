# ==========================================
# .env - Local Development Environment
# ==========================================

# Frontend Environment Variables (VITE_)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_G2PAY_MERCHANT_ID=your_g2pay_merchant_id

# Google Pay Configuration (Frontend)
VITE_GOOGLE_MERCHANT_ID=your_google_merchant_id
VITE_GOOGLE_PAY_MERCHANT_NAME=Your App Name
VITE_GOOGLE_PAY_GATEWAY=crst
VITE_GOOGLE_PAY_GATEWAY_MERCHANT_ID=your_g2pay_merchant_id

# Error Tracking (Sentry)
VITE_SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id

# Supabase CLI Access Token (for local deployments)
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# ==========================================
# .env.github - GitHub Actions Secrets
# ==========================================
# Add these in: GitHub Repo > Settings > Secrets and variables > Actions

# SUPABASE_URL=your_supabase_project_url
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ==========================================
# .env.supabase - Supabase Edge Functions
# ==========================================
# Deploy with: ./deploy-secrets.sh

# Email Notification Secrets
# MAILGUN_API_KEY=your_mailgun_api_key_here
# MAILGUN_DOMAIN=your_mailgun_domain
# SMTP_FROM=your_smtp_from_email

# G2Pay Payment Secrets
# G2PAY_MERCHANT_ID=your_g2pay_merchant_id
# G2PAY_SIGNATURE_KEY=your_g2pay_signature_key_here
# G2PAY_DIRECT_API_URL=https://payments.g2pay.co.uk/direct/
# G2PAY_HOSTED_URL=https://checkout.g2pay.co.uk/postbridge/g2paymodal

# Supabase Configuration
# SUPABASE_URL=your_supabase_project_url
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Public Site URL
# PUBLIC_SITE_URL=https://your-site.com

# CORS Configuration
# ALLOWED_ORIGINS=https://your-site.com,https://www.your-site.com